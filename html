<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTA MC | Ultra Premium Hub</title>
    <style>
        /* ULTRA LÜKS SİBER OYUNCU TASARIMI */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
        }

        body {
            background: #0a0516;
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            overflow: hidden;
            position: relative;
        }

        /* Arka Plandaki Lüks Neon Işık Dalgaları */
        body::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: linear-gradient(45deg, #ff007f, #7928ca);
            border-radius: 50%;
            top: -50px;
            left: -50px;
            filter: blur(150px);
            opacity: 0.5;
            z-index: 0;
        }

        body::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: linear-gradient(45deg, #00dfa2, #00f5ff);
            border-radius: 50%;
            bottom: -100px;
            right: -100px;
            filter: blur(150px);
            opacity: 0.4;
            z-index: 0;
        }

        /* Aşırı Lüks Premium Kart */
        .cyber-card {
            background: rgba(15, 10, 32, 0.7);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 2px solid rgba(255, 255, 255, 0.05);
            border-radius: 32px;
            padding: 45px 35px;
            width: 100%;
            max-width: 540px;
            text-align: center;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.8), 
                        0 0 50px rgba(121, 40, 202, 0.2),
                        inset 0 1px 0 rgba(255, 255, 255, 0.1);
            position: relative;
            z-index: 1;
            animation: ultraFirlat 1s cubic-bezier(0.17, 0.67, 0.83, 0.67);
        }

        @keyframes ultraFirlat {
            0% { transform: scale(0.8) translateY(50px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }

        /* Canlı Durum Rozeti */
        .live-badge {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(90deg, rgba(0, 245, 255, 0.1), rgba(0, 223, 162, 0.1));
            border: 1px solid #00dfa2;
            padding: 8px 20px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 800;
            color: #00dfa2;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
            box-shadow: 0 0 20px rgba(0, 223, 162, 0.3);
        }

        .neon-dot {
            width: 10px;
            height: 10px;
            background-color: #00dfa2;
            border-radius: 50%;
            box-shadow: 0 0 10px #00dfa2;
            animation: siberNabiz 1s infinite alternate;
        }

        @keyframes siberNabiz {
            from { transform: scale(0.8); opacity: 0.5; filter: drop-shadow(0 0 2px #00dfa2); }
            to { transform: scale(1.2); opacity: 1; filter: drop-shadow(0 0 8px #00dfa2); }
        }

        /* Altın ve Siber Geçişli Başlık */
        h1 {
            font-size: 42px;
            font-weight: 900;
            background: linear-gradient(90deg, #00f5ff, #ff007f, #ffdd00);
            background-size: 400% 400%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
            letter-spacing: 1.

